---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="container py-16">
        <h1 class="text-4xl font-display font-bold mb-6">Contact</h1>
        <p class="text-lg text-muted-foreground leading-relaxed mb-4">
            Du kannst uns jederzeit fuer Fragen, Feedback oder Zusammenarbeit
            erreichen.
        </p>
        <p class="text-muted-foreground">
            E-Mail: <a href="mailto:hello@example.com" class="underline">hello@example.com</a>
        </p>
    </main>
</Layout>

